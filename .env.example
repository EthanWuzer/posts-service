MONGO_URI=mongodb://mongo:27017/posts
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# JWT verification — must match the users-service issuer settings.
JWT_ISSUER=instaclone
JWT_AUDIENCE=instaclone-users

# Base URL of the users-service (used to resolve usernames and fetch the JWT public key)
USERS_SERVICE_BASE_URL=http://users-api:8080

# Must match the API_KEY value in the users-service .env — used to authenticate
# the GET /api/auth/jwt-key request that fetches the RSA public key on startup.
USERS_SERVICE_API_KEY=<api-key-shared-with-users-service>

# Stored on new posts/comments as a placeholder until profile pictures are
# supported by the users-service. Leave empty or set a default avatar URL.
DEFAULT_PROFILE_PICTURE_URL=
